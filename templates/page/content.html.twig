<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title ?? 'Page' }}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --paper: #f4efe6;
            --paper-raised: #fbf8f1;
            --paper-sunken: #ebe5d6;
            --ink: #1a1813;
            --ink-soft: #4a4438;
            --ink-faded: #857c6d;
            --ink-ghost: #c4bca8;
            --accent: #9c2a2a;
            --font-display: 'Fraunces', Georgia, serif;
            --font-mono: 'JetBrains Mono', 'Courier New', monospace;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        html, body { min-height: 100%; }
        body {
            background: var(--paper);
            color: var(--ink-soft);
            font-family: var(--font-display);
            font-size: 1.0625rem;
            line-height: 1.7;
            font-optical-sizing: auto;
            position: relative;
            padding: 3rem 1.5rem 4rem;
        }
        body::before {
            content: "";
            position: fixed;
            inset: 0;
            pointer-events: none;
            opacity: 0.05;
            mix-blend-mode: multiply;
            background-image: url("data:image/svg+xml;utf8,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 240 240'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='2' stitchTiles='stitch'/%3E%3CfeColorMatrix values='0 0 0 0 0.10  0 0 0 0 0.09  0 0 0 0 0.07  0 0 0 0.6 0'/%3E%3C/filter%3E%3Crect width='240' height='240' filter='url(%23n)'/%3E%3C/svg%3E");
        }
        .markdown-content {
            max-width: 720px;
            margin: 0 auto;
            position: relative;
            z-index: 1;
        }
        .markdown-content h1,
        .markdown-content h2,
        .markdown-content h3,
        .markdown-content h4,
        .markdown-content h5,
        .markdown-content h6 {
            font-family: var(--font-display);
            color: var(--ink);
            font-weight: 600;
            letter-spacing: -0.02em;
            line-height: 1.2;
        }
        .markdown-content h1 {
            font-size: 2.5rem;
            font-variation-settings: "opsz" 144;
            margin: 2rem 0 1.25rem;
            border-bottom: 2px dashed var(--ink-ghost);
            padding-bottom: 0.6rem;
        }
        .markdown-content h2 {
            font-size: 1.85rem;
            font-variation-settings: "opsz" 80;
            margin: 2rem 0 0.85rem;
        }
        .markdown-content h3 {
            font-size: 1.4rem;
            margin: 1.6rem 0 0.6rem;
        }
        .markdown-content h4 { font-size: 1.15rem; margin: 1.3rem 0 0.5rem; }
        .markdown-content p { margin-bottom: 1.1rem; }
        .markdown-content a {
            color: var(--accent);
            text-decoration: underline;
            text-decoration-thickness: 1px;
            text-underline-offset: 0.2em;
            text-decoration-color: var(--ink-ghost);
        }
        .markdown-content a:hover {
            text-decoration-color: var(--accent);
        }
        .markdown-content strong { color: var(--ink); font-weight: 600; }
        .markdown-content em { font-style: italic; }
        .markdown-content pre {
            background: var(--paper-sunken);
            border: 1px solid var(--ink-ghost);
            border-top: 2px dashed var(--ink-soft);
            border-radius: 0 0 3px 3px;
            padding: 1rem 1.25rem;
            overflow-x: auto;
            margin: 0 0 1.25rem;
            font-family: var(--font-mono);
            font-size: 0.875rem;
            line-height: 1.55;
            color: var(--ink);
        }
        .markdown-content code {
            font-family: var(--font-mono);
            font-size: 0.875em;
            color: var(--ink);
        }
        .markdown-content :not(pre) > code {
            background: var(--paper-sunken);
            padding: 0.12em 0.4em;
            border-radius: 2px;
            border: 1px solid var(--ink-ghost);
        }
        .markdown-content pre code {
            background: none;
            border: 0;
            padding: 0;
        }
        .markdown-content blockquote {
            border-left: 3px solid var(--accent);
            padding: 0.25rem 0 0.25rem 1.25rem;
            margin: 0 0 1.25rem;
            color: var(--ink-faded);
            font-style: italic;
        }
        .markdown-content table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 1.5rem;
            font-family: var(--font-mono);
            font-size: 0.875rem;
        }
        .markdown-content th,
        .markdown-content td {
            border-bottom: 1px solid var(--ink-ghost);
            padding: 0.65rem 0.85rem;
            text-align: left;
            color: var(--ink-soft);
        }
        .markdown-content th {
            color: var(--ink);
            font-weight: 500;
            font-variant: small-caps;
            letter-spacing: 0.05em;
            border-top: 1px solid var(--ink);
            border-bottom: 1px solid var(--ink);
            background: transparent;
        }
        .markdown-content img {
            max-width: 100%;
            height: auto;
            border: 1px solid var(--ink-ghost);
            border-radius: 2px;
        }
        .markdown-content ul,
        .markdown-content ol {
            margin-bottom: 1.1rem;
            padding-left: 1.6rem;
        }
        .markdown-content li { margin-bottom: 0.35rem; }
        .markdown-content li::marker { color: var(--accent); }
        .markdown-content hr {
            border: 0;
            border-top: 1px dashed var(--ink-ghost);
            margin: 2rem 0;
        }
        ::selection { background: var(--ink); color: var(--paper); }
    </style>
</head>
<body>
    <div class="markdown-content">
        {{ contentHtml|raw }}
    </div>

    {% if trackToken is not null %}
    {% include 'page/_tracking_script.html.twig' %}
    {% endif %}
</body>
</html>
