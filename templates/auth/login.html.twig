{% extends 'base.html.twig' %}

{% block title %}Login - Gotcha URL{% endblock %}

{% block body %}
<section class="login-hero">
    <div class="login-hero__brand">
        <h1>Gotcha<br><em>URL.</em></h1>
        <div class="login-hero__rule"></div>
        <p class="login-hero__tagline">
            <strong>A field manual for your links.</strong><br>
            Shorten URLs, publish pages, and read every visitor's fingerprint &mdash; right down to GPU and color depth.
        </p>
    </div>

    <div class="login-hero__form">
        <div class="login-hero__form-title">— Sign in</div>

        {% if error %}
            <div class="alert alert-danger">
                Invalid account code. Please try again.
            </div>
        {% endif %}

        <form method="post" action="{{ path('app_login') }}">
            <div class="mb-3">
                <label for="account_code" class="form-label">Account Code</label>
                <input type="text" class="form-control" id="account_code" name="account_code"
                       placeholder="xxxx-xxxx-xxxx" required autofocus>
            </div>
            <button type="submit" class="btn btn-primary w-100 mb-3">Enter dashboard &rarr;</button>
        </form>

        <hr>

        <div class="text-center">
            <p class="text-muted small mb-2">No account?</p>
            <a href="{{ path('app_register') }}" class="btn btn-outline-success w-100">Issue a new code</a>
        </div>
    </div>
</section>
{% endblock %}
