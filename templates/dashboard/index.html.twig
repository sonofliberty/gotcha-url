{% extends 'base.html.twig' %}

{% block title %}Dashboard - Gotcha URL{% endblock %}

{% block body %}
<section class="card border-0 shadow-sm mb-4">
    <div class="card-body p-4">
        <h5 class="card-title mb-1">Create new link</h5>
        <p class="text-muted small mb-4">Shorten a URL or publish a Markdown page.</p>

        <form method="post" action="{{ path('app_create_link') }}" id="create-link-form">
            <input type="hidden" name="link_type" id="link-type-input" value="redirect">

            <fieldset class="mb-3">
                <legend class="form-label small mb-2">Type</legend>
                <div class="form-check form-check-inline">
                    <input type="radio" class="form-check-input" name="link_type_radio"
                           id="type-redirect" value="redirect" checked>
                    <label class="form-check-label" for="type-redirect">Redirect</label>
                </div>
                <div class="form-check form-check-inline">
                    <input type="radio" class="form-check-input" name="link_type_radio"
                           id="type-page" value="page">
                    <label class="form-check-label" for="type-page">Page</label>
                </div>
            </fieldset>

            <div id="redirect-fields" class="mb-3">
                <label for="target-url-input" class="form-label">Destination URL</label>
                <input type="url" class="form-control" name="target_url" id="target-url-input"
                       placeholder="https://example.com/very/long/path" required>
            </div>

            <div id="page-fields" class="mb-3 d-none">
                <label for="markdown-content-input" class="form-label">Page content</label>
                <textarea class="form-control" name="markdown_content" id="markdown-content-input"
                          rows="6" placeholder="# Hello&#10;&#10;Markdown or safe HTML..."></textarea>
                <div class="form-text">Markdown and safe HTML supported. Scripts and unsafe URL schemes are stripped.</div>
            </div>

            <div class="mb-4">
                <label for="label-input" class="form-label">
                    Label <span class="text-muted fw-normal">(optional)</span>
                </label>
                <input type="text" class="form-control" name="label" id="label-input"
                       placeholder="my-campaign" maxlength="100">
            </div>

            <button type="submit" class="btn btn-primary px-4" id="create-link-submit">
                <span class="submit-verb"
                      data-verb-redirect="Shorten link"
                      data-verb-page="Publish page">Shorten link</span>
            </button>
        </form>
    </div>
</section>

<details class="card border-0 shadow-sm mb-4">
    <summary class="card-body py-3 d-flex align-items-center justify-content-between summary-row">
        <div>
            <h6 class="mb-0">API access</h6>
            <span class="text-muted small">REST endpoint authenticated with Bearer token</span>
        </div>
        <span class="text-muted small">expand</span>
    </summary>
    <div class="card-body pt-0 px-4 pb-4">
        <p class="small text-muted mb-3">
            Create links programmatically. See the <a href="/api/doc" target="_blank">interactive API docs</a> for the full reference.
        </p>

        <label for="api-token-input" class="form-label small">Your API token</label>
        <div class="input-group input-group-sm mb-3">
            <input type="password" class="form-control font-monospace" id="api-token-input"
                   value="{{ app.user.accountCode }}" readonly>
            <button type="button" class="btn btn-outline-secondary" data-toggle-password="api-token-input">Show</button>
            <button type="button" class="btn btn-outline-secondary btn-copy"
                    data-url="{{ app.user.accountCode }}">Copy</button>
        </div>

        <pre class="dashboard-codeblock mb-0"><code>curl -X POST {{ app.request.schemeAndHttpHost }}/api/v1/links \
  -H "Authorization: Bearer &lt;your-token&gt;" \
  -H "Content-Type: application/json" \
  -d '{"target_url":"https://example.com"}'</code></pre>
    </div>
</details>

<h5 class="mb-3">
    Your links
    <span class="text-muted fw-normal small">({{ links|length }})</span>
</h5>

{% if links|length == 0 %}
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5">
            <p class="text-muted mb-1 fw-medium">No links yet</p>
            <p class="text-muted small mb-0">Use the form above to create your first short link.</p>
        </div>
    </div>
{% else %}
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Destination</th>
                        <th>Label</th>
                        <th>Short Link</th>
                        <th>Visits</th>
                        <th>Tracking</th>
                        <th>Created</th>
                    </tr>
                </thead>
                <tbody>
                    {% for link in links %}
                        <tr class="row-clickable" data-href="{{ path('app_link_detail', {id: link.id}) }}">
                            <td class="text-truncate cell-destination">
                                {% if link.page %}
                                    <span class="badge bg-secondary">Page</span>
                                    <span class="text-muted small">Markdown content</span>
                                {% else %}
                                    <span title="{{ link.targetUrl }}">{{ link.targetUrl }}</span>
                                {% endif %}
                            </td>
                            <td>
                                <span class="label-display" data-link-id="{{ link.id }}" data-label="{{ link.label ?? '' }}">
                                    {% if link.label %}
                                        {{ link.label }}
                                    {% else %}
                                        <span class="text-muted fst-italic">+ label</span>
                                    {% endif %}
                                </span>
                            </td>
                            <td class="text-nowrap">
                                <code class="me-1">{{ url('app_track', {slug: link.slug}) }}</code>
                                <button type="button" class="btn btn-sm btn-outline-secondary btn-copy"
                                        data-url="{{ url('app_track', {slug: link.slug}) }}"
                                        title="Copy short URL">Copy</button>
                            </td>
                            <td><span class="badge bg-info">{{ link.visitCount }}</span></td>
                            <td class="text-center">
                                <div class="form-check form-switch d-inline-block mb-0">
                                    <input class="form-check-input tracking-toggle"
                                           type="checkbox"
                                           role="switch"
                                           data-link-id="{{ link.id }}"
                                           {{ link.trackingEnabled ? 'checked' : '' }}>
                                </div>
                            </td>
                            <td class="text-nowrap">
                                <time datetime="{{ link.createdAt|date('c') }}">{{ link.createdAt|date('M j, Y') }}</time>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {% if totalPages > 1 %}
        <nav class="mt-3">
            <ul class="pagination justify-content-center">
                <li class="page-item {{ currentPage <= 1 ? 'disabled' }}">
                    <a class="page-link" href="{{ path('app_dashboard', {page: currentPage - 1}) }}">Previous</a>
                </li>
                {% for p in 1..totalPages %}
                    <li class="page-item {{ p == currentPage ? 'active' }}">
                        <a class="page-link" href="{{ path('app_dashboard', {page: p}) }}">{{ p }}</a>
                    </li>
                {% endfor %}
                <li class="page-item {{ currentPage >= totalPages ? 'disabled' }}">
                    <a class="page-link" href="{{ path('app_dashboard', {page: currentPage + 1}) }}">Next</a>
                </li>
            </ul>
        </nav>
    {% endif %}
{% endif %}
{% endblock %}
