{% extends 'base.html.twig' %}

{% block title %}Dashboard - Gotcha URL{% endblock %}

{% block body %}
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body py-3">
        <form method="post" action="{{ path('app_create_link') }}" id="create-link-form">
            <input type="hidden" name="link_type" id="link-type-input" value="redirect">
            <div class="btn-group btn-group-sm mb-2 w-100" role="group">
                <input type="radio" class="btn-check" name="link_type_radio" id="type-redirect" value="redirect" checked>
                <label class="btn btn-outline-primary" for="type-redirect">Redirect Link</label>
                <input type="radio" class="btn-check" name="link_type_radio" id="type-page" value="page">
                <label class="btn btn-outline-primary" for="type-page">Content Page</label>
            </div>
            <div id="redirect-fields">
                <div class="input-group mb-2">
                    <span class="input-group-text bg-white">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="text-muted" viewBox="0 0 16 16">
                            <path d="M4.715 6.542 3.343 7.914a3 3 0 1 0 4.243 4.243l1.828-1.829A3 3 0 0 0 8.586 5.5L8 6.086a1 1 0 0 0-.154.199 2 2 0 0 1 .861 3.337L6.88 11.45a2 2 0 1 1-2.83-2.83l.793-.792a4 4 0 0 1-.128-1.287z"/>
                            <path d="M6.586 4.672A3 3 0 0 0 7.414 9.5l.775-.776a2 2 0 0 1-.896-3.346L9.12 3.55a2 2 0 1 1 2.83 2.83l-.793.792c.112.42.155.855.128 1.287l1.372-1.372a3 3 0 1 0-4.243-4.243z"/>
                        </svg>
                    </span>
                    <input type="url" class="form-control" name="target_url" id="target-url-input"
                           placeholder="Paste a URL to shorten..." required>
                    <button type="submit" class="btn btn-primary">Shorten</button>
                </div>
            </div>
            <div id="page-fields" class="d-none">
                <textarea class="form-control mb-1" name="markdown_content" id="markdown-content-input"
                          rows="5" placeholder="Write your page content in Markdown or HTML..."></textarea>
                <small class="text-muted d-block mb-2">Markdown and safe HTML supported. Scripts, event handlers, and unsafe URL schemes are stripped.</small>
                <button type="submit" class="btn btn-primary">Create Page</button>
            </div>
            <input type="text" class="form-control form-control-sm" name="label"
                   placeholder="Label (optional)" maxlength="100">
        </form>
    </div>
</div>

<details class="card border-0 shadow-sm mb-4">
    <summary class="card-body py-2 d-flex align-items-center justify-content-between" style="cursor:pointer; list-style:none;">
        <span class="fw-medium">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-1" viewBox="0 0 16 16">
                <path d="M5.5 7a.5.5 0 0 0 0 1h5a.5.5 0 0 0 0-1zM5 9.5a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5m0 2a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5"/>
                <path d="M9.5 0H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V4.5zM9 1.5v2A1.5 1.5 0 0 0 10.5 5h2V14a1 1 0 0 1-1 1h-8a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1z"/>
            </svg>
            API Access
        </span>
        <span class="text-muted small">click to expand</span>
    </summary>
    <div class="card-body pt-0">
        <p class="small mb-2">
            Use the REST API to create links programmatically. Authenticate with your account code as a Bearer token.
            See the <a href="/api/doc" target="_blank">interactive API docs</a> for full reference.
        </p>
        <label class="form-label small mb-1">Your API token (account code)</label>
        <div class="input-group input-group-sm mb-2">
            <input type="password" class="form-control font-monospace" id="api-token-input"
                   value="{{ app.user.accountCode }}" readonly>
            <button type="button" class="btn btn-outline-secondary" id="api-token-show">Show</button>
            <button type="button" class="btn btn-outline-secondary" id="api-token-copy">Copy</button>
        </div>
        <div class="bg-light p-2 rounded small font-monospace text-break">
            curl -X POST {{ app.request.schemeAndHttpHost }}/api/v1/links \<br>
            &nbsp;&nbsp;-H "Authorization: Bearer &lt;your-token&gt;" \<br>
            &nbsp;&nbsp;-H "Content-Type: application/json" \<br>
            &nbsp;&nbsp;-d '{"target_url":"https://example.com"}'
        </div>
    </div>
</details>
<script>
document.getElementById('api-token-show')?.addEventListener('click', function() {
    var input = document.getElementById('api-token-input');
    if (input.type === 'password') { input.type = 'text'; this.textContent = 'Hide'; }
    else { input.type = 'password'; this.textContent = 'Show'; }
});
document.getElementById('api-token-copy')?.addEventListener('click', function() {
    var input = document.getElementById('api-token-input');
    navigator.clipboard.writeText(input.value).then(() => {
        var orig = this.textContent;
        this.textContent = 'Copied!';
        this.classList.replace('btn-outline-secondary', 'btn-success');
        setTimeout(() => { this.textContent = orig; this.classList.replace('btn-success', 'btn-outline-secondary'); }, 1500);
    });
});
</script>

{% if links|length == 0 %}
    <div class="text-center py-5 text-muted">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="mb-3 opacity-25" viewBox="0 0 16 16">
            <path d="M4.715 6.542 3.343 7.914a3 3 0 1 0 4.243 4.243l1.828-1.829A3 3 0 0 0 8.586 5.5L8 6.086a1 1 0 0 0-.154.199 2 2 0 0 1 .861 3.337L6.88 11.45a2 2 0 1 1-2.83-2.83l.793-.792a4 4 0 0 1-.128-1.287z"/>
            <path d="M6.586 4.672A3 3 0 0 0 7.414 9.5l.775-.776a2 2 0 0 1-.896-3.346L9.12 3.55a2 2 0 1 1 2.83 2.83l-.793.792c.112.42.155.855.128 1.287l1.372-1.372a3 3 0 1 0-4.243-4.243z"/>
        </svg>
        <p class="mb-1 fw-medium">No links yet</p>
        <p class="small">Paste a URL above to create your first short link.</p>
    </div>
{% else %}
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Destination</th>
                    <th>Label</th>
                    <th>Short Link</th>
                    <th>Visits</th>
                    <th>Tracking</th>
                    <th>Created</th>
                </tr>
            </thead>
            <tbody>
                {% for link in links %}
                    <tr style="cursor:pointer" onclick="window.location='{{ path('app_link_detail', {id: link.id}) }}'">
                        <td class="text-truncate" style="max-width: 350px;">
                            {% if link.page %}
                                <span class="badge bg-secondary">Page</span>
                                <span class="text-muted small">Markdown content</span>
                            {% else %}
                                <span title="{{ link.targetUrl }}">{{ link.targetUrl }}</span>
                            {% endif %}
                        </td>
                        <td onclick="event.stopPropagation()">
                            <span class="label-display" data-link-id="{{ link.id }}" data-label="{{ link.label ?? '' }}">
                                {% if link.label %}
                                    {{ link.label }}
                                {% else %}
                                    <span class="text-muted fst-italic">+ label</span>
                                {% endif %}
                            </span>
                        </td>
                        <td class="text-nowrap">
                            <code class="me-1">{{ url('app_track', {slug: link.slug}) }}</code>
                            <button type="button" class="btn btn-sm btn-outline-secondary btn-copy"
                                    data-url="{{ url('app_track', {slug: link.slug}) }}"
                                    onclick="event.stopPropagation()" title="Copy short URL">Copy</button>
                        </td>
                        <td><span class="badge bg-info">{{ link.visitCount }}</span></td>
                        <td onclick="event.stopPropagation()" class="text-center">
                            <div class="form-check form-switch d-inline-block mb-0">
                                <input class="form-check-input tracking-toggle"
                                       type="checkbox"
                                       role="switch"
                                       data-link-id="{{ link.id }}"
                                       {{ link.trackingEnabled ? 'checked' : '' }}>
                            </div>
                        </td>
                        <td class="text-nowrap">
                            <time datetime="{{ link.createdAt|date('c') }}">{{ link.createdAt|date('M j, Y') }}</time>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {% if totalPages > 1 %}
        <nav class="mt-3">
            <ul class="pagination justify-content-center">
                <li class="page-item {{ currentPage <= 1 ? 'disabled' }}">
                    <a class="page-link" href="{{ path('app_dashboard', {page: currentPage - 1}) }}">Previous</a>
                </li>
                {% for p in 1..totalPages %}
                    <li class="page-item {{ p == currentPage ? 'active' }}">
                        <a class="page-link" href="{{ path('app_dashboard', {page: p}) }}">{{ p }}</a>
                    </li>
                {% endfor %}
                <li class="page-item {{ currentPage >= totalPages ? 'disabled' }}">
                    <a class="page-link" href="{{ path('app_dashboard', {page: currentPage + 1}) }}">Next</a>
                </li>
            </ul>
        </nav>
    {% endif %}
{% endif %}
{% endblock %}

